{
  "name": "appshield",
  "version": "1.0.0",
  "description": "AI-powered security scanner CLI that uses Claude to find vulnerabilities in your code",
  "main": "dist/index.js",
  "bin": {
    "appshield": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:first": "standard-version --first-release"
  },
  "keywords": [
    "security",
    "scanner",
    "cli",
    "vulnerability",
    "ai",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "dotenv": "^16.4.7",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
